# MCP Web Client Configuration

# MCP Gateway Configuration (Primary - connects through centralized gateway)
MCP_GATEWAY_URL=http://mcp-gateway:8080

# Legacy: Direct MCP Server Configuration (only used if not using gateway)
# WEATHER_SERVER_URL=http://weather-server:8000/mcp
# NEWS_SERVER_URL=http://news-server:8000/mcp

# Azure OpenAI Configuration (Required for chat functionality)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Web Client Server Configuration
HOST=0.0.0.0
PORT=3000

# Application Configuration  
LOG_LEVEL=INFO

# MCP Gateway Environment Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=false
LOG_LEVEL=INFO

# Health Monitoring
HEALTH_CHECK_INTERVAL=30
HEALTH_TIMEOUT=10

# Tool Discovery
TOOL_DISCOVERY_INTERVAL=60

# CORS Configuration
CORS_ORIGINS=["*"]

# MCP Servers Configuration
# Weather Server
MCP_SERVERS__WEATHER__NAME=weather
MCP_SERVERS__WEATHER__DESCRIPTION=Weather information service
MCP_SERVERS__WEATHER__HOST=localhost
MCP_SERVERS__WEATHER__PORT=8001
MCP_SERVERS__WEATHER__ENABLED=true
MCP_SERVERS__WEATHER__TAGS=["weather", "forecast"]

# News Server
MCP_SERVERS__NEWS__NAME=news
MCP_SERVERS__NEWS__DESCRIPTION=News and articles service
MCP_SERVERS__NEWS__HOST=localhost
MCP_SERVERS__NEWS__PORT=8002
MCP_SERVERS__NEWS__ENABLED=true
MCP_SERVERS__NEWS__TAGS=["news", "articles"]

# Add more servers as needed
# MCP_SERVERS__BILLING__NAME=billing
# MCP_SERVERS__BILLING__DESCRIPTION=Billing and invoicing service
